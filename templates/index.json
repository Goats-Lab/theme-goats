    "custom_liquid_bUpbnA": {
      "type": "custom-liquid",
      "custom_css": [],
      "name": "t:sections.custom_liquid.presets.custom_liquid.name",
      "settings": {
        "color_scheme": "scheme-1",
        "separate_section_with_border": false,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "{%- assign handles = \"pandoras, tiffany, colecao-swarovski\" | split: \", \" -%}\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Montserrat:wght@300;400;500;600&display=swap');\n\n  .mc-cat {\n    padding: 5rem 0;\n    background: #fff;\n    font-family: 'Montserrat', sans-serif;\n    overflow: hidden;\n  }\n\n  .mc-cat__inner {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 0 24px;\n  }\n\n  .mc-cat__head {\n    text-align: center;\n    margin-bottom: 3rem;\n  }\n\n  .mc-cat__kicker {\n    font-size: .65rem;\n    text-transform: uppercase;\n    letter-spacing: .35em;\n    color: #d4638f;\n    font-weight: 600;\n    margin-bottom: .8rem;\n  }\n\n  .mc-cat__title {\n    font-family: 'Playfair Display', serif;\n    font-size: 2.2rem;\n    font-weight: 500;\n    color: #1a1a1a;\n    margin: 0 0 .6rem;\n  }\n\n  .mc-cat__sub {\n    font-size: .9rem;\n    color: #888;\n    font-weight: 300;\n    max-width: 400px;\n    margin: 0 auto;\n    line-height: 1.6;\n  }\n\n  .mc-cat__divider {\n    width: 50px;\n    height: 2px;\n    background: #d4638f;\n    margin: 1.2rem auto 0;\n    border-radius: 2px;\n  }\n\n  /* Carousel */\n  .mc-cat__track-wrap {\n    position: relative;\n  }\n\n  .mc-cat__track {\n    display: flex;\n    gap: 1.5rem;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    scroll-behavior: smooth;\n    -webkit-overflow-scrolling: touch;\n    padding: 0 24px 1.5rem;\n    scrollbar-width: none;\n  }\n\n  .mc-cat__track::-webkit-scrollbar {\n    display: none;\n  }\n\n  /* Arrows */\n  .mc-cat__arrows {\n    display: flex;\n    justify-content: center;\n    gap: .75rem;\n    margin-top: 2rem;\n  }\n\n  .mc-cat__arr {\n    width: 44px;\n    height: 44px;\n    border-radius: 50%;\n    border: 1.5px solid #e0e0e0;\n    background: #fff;\n    color: #1a1a1a;\n    font-size: 1.1rem;\n    cursor: pointer;\n    transition: all .25s ease;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .mc-cat__arr:hover {\n    background: #d4638f;\n    border-color: #d4638f;\n    color: #fff;\n  }\n\n  /* Card */\n  .mc-cat__card {\n    scroll-snap-align: center;\n    min-width: 280px;\n    max-width: 300px;\n    flex: 0 0 auto;\n    text-decoration: none;\n    color: #1a1a1a;\n    border-radius: 16px;\n    overflow: hidden;\n    background: #fff;\n    box-shadow: 0 4px 20px rgba(0,0,0,.06);\n    border: 1px solid rgba(0,0,0,.04);\n    transition: all .35s ease;\n  }\n\n  .mc-cat__card:hover {\n    transform: translateY(-8px);\n    box-shadow: 0 20px 50px rgba(212,99,143,.15);\n  }\n\n  .mc-cat__media {\n    position: relative;\n    aspect-ratio: 3 / 4;\n    overflow: hidden;\n    border-radius: 16px 16px 0 0;\n  }\n\n  .mc-cat__media img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    transition: transform .7s ease;\n  }\n\n  .mc-cat__card:hover img {\n    transform: scale(1.06);\n  }\n\n  .mc-cat__gradient {\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,.5) 100%);\n    opacity: 0;\n    transition: opacity .35s ease;\n  }\n\n  .mc-cat__card:hover .mc-cat__gradient {\n    opacity: 1;\n  }\n\n  .mc-cat__cta {\n    position: absolute;\n    bottom: 1.2rem;\n    left: 50%;\n    transform: translateX(-50%) translateY(10px);\n    opacity: 0;\n    font-size: .7rem;\n    text-transform: uppercase;\n    letter-spacing: .2em;\n    font-weight: 600;\n    color: #fff;\n    background: #d4638f;\n    padding: .55rem 1.6rem;\n    border-radius: 50px;\n    transition: all .35s ease;\n    white-space: nowrap;\n  }\n\n  .mc-cat__card:hover .mc-cat__cta {\n    opacity: 1;\n    transform: translateX(-50%) translateY(0);\n  }\n\n  .mc-cat__info {\n    padding: 1.2rem 1.2rem 1.4rem;\n    text-align: center;\n  }\n\n  .mc-cat__brand {\n    font-size: .6rem;\n    text-transform: uppercase;\n    letter-spacing: .25em;\n    color: #d4638f;\n    font-weight: 600;\n    margin-bottom: .4rem;\n  }\n\n  .mc-cat__name {\n    font-family: 'Playfair Display', serif;\n    font-size: 1.15rem;\n    font-weight: 500;\n    margin: 0 0 .4rem;\n    color: #1a1a1a;\n  }\n\n  .mc-cat__desc {\n    font-size: .8rem;\n    color: #999;\n    line-height: 1.5;\n    font-weight: 300;\n  }\n\n  /* Dots */\n  .mc-cat__dots {\n    display: flex;\n    justify-content: center;\n    gap: .5rem;\n    margin-top: 1.5rem;\n  }\n\n  .mc-cat__dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    background: #e0e0e0;\n    border: none;\n    cursor: pointer;\n    transition: all .25s ease;\n    padding: 0;\n  }\n\n  .mc-cat__dot.active {\n    background: #d4638f;\n    width: 24px;\n    border-radius: 4px;\n  }\n\n  @media (max-width: 768px) {\n    .mc-cat { padding: 3rem 0; }\n    .mc-cat__title { font-size: 1.6rem; }\n    .mc-cat__card { min-width: 240px; max-width: 260px; }\n    .mc-cat__arrows { display: none; }\n  }\n</style>\n\n<section class=\"mc-cat\" id=\"mc-catalog-carousel\">\n  <div class=\"mc-cat__inner\">\n    <div class=\"mc-cat__head\">\n      <p class=\"mc-cat__kicker\"></p>\n      <h2 class=\"mc-cat__title\">Pronta Entrega</h2>\n      <p class=\"mc-cat__sub\">Explore peças Pronta Entrega inspiradas nas maiores marcas do mundo.</p>\n      <div class=\"mc-cat__divider\"></div>\n    </div>\n\n    <div class=\"mc-cat__track-wrap\">\n      <div class=\"mc-cat__track\" id=\"mcCatTrack\">\n        {%- for handle in handles -%}\n          {%- assign coll = collections[handle] -%}\n          {%- if coll and coll.featured_image -%}\n            <a href=\"{{ coll.url }}\" class=\"mc-cat__card\">\n              <div class=\"mc-cat__media\">\n                {{ coll.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', draggable: 'false' }}\n                <div class=\"mc-cat__gradient\"></div>\n                <span class=\"mc-cat__cta\">Ver Coleção →</span>\n              </div>\n              <div class=\"mc-cat__info\">\n                <p class=\"mc-cat__brand\">Inspirado em</p>\n                <h3 class=\"mc-cat__name\">{{ coll.title }}</h3>\n                {%- if coll.description != blank -%}\n                  <p class=\"mc-cat__desc\">{{ coll.description | strip_html | truncate: 80 }}</p>\n                {%- endif -%}\n              </div>\n            </a>\n          {%- endif -%}\n        {%- endfor -%}\n      </div>\n\n      <div class=\"mc-cat__arrows\">\n        <button class=\"mc-cat__arr\" onclick=\"mcScroll(-1)\" aria-label=\"Anterior\">‹</button>\n        <button class=\"mc-cat__arr\" onclick=\"mcScroll(1)\" aria-label=\"Próximo\">›</button>\n      </div>\n\n      <div class=\"mc-cat__dots\" id=\"mcCatDots\"></div>\n    </div>\n  </div>\n</section>\n\n<script>\n(function(){\n  const track = document.getElementById('mcCatTrack');\n  const dotsWrap = document.getElementById('mcCatDots');\n  if (!track) return;\n\n  const cards = track.querySelectorAll('.mc-cat__card');\n  const total = cards.length;\n\n  // Build dots\n  cards.forEach((_, i) => {\n    const dot = document.createElement('button');\n    dot.className = 'mc-cat__dot' + (i === 0 ? ' active' : '');\n    dot.setAttribute('aria-label', 'Slide ' + (i + 1));\n    dot.onclick = () => {\n      cards[i].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });\n    };\n    dotsWrap.appendChild(dot);\n  });\n\n  // Update dots on scroll\n  const dots = dotsWrap.querySelectorAll('.mc-cat__dot');\n  const observer = new IntersectionObserver((entries) => {\n    entries.forEach(e => {\n      if (e.isIntersecting) {\n        const idx = [...cards].indexOf(e.target);\n        dots.forEach((d, i) => d.classList.toggle('active', i === idx));\n      }\n    });\n  }, { root: track, threshold: 0.6 });\n\n  cards.forEach(c => observer.observe(c));\n\n  // Arrow scroll\n  window.mcScroll = function(dir) {\n    const cardW = cards[0].offsetWidth + 24;\n    track.scrollBy({ left: dir * cardW, behavior: 'smooth' });\n  };\n})();\n</script>",
        "text_alignment": "center"
      }
    },
