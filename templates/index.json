        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div class=\"mc-tiktok-wrapper\">\n  <blockquote class=\"tiktok-embed\"\n              cite=\"https://www.tiktok.com/@my.charms.br\"\n              data-unique-id=\"my.charms.br\"\n              data-embed-type=\"creator\"\n              style=\"max-width:780px; min-width:288px;\">\n    <section>\n      <a target=\"_blank\" href=\"https://www.tiktok.com/@my.charms.br?refer=creator_embed\">@my.charms.br</a>\n    </section>\n  </blockquote>\n</div>\n<script async src=\"https://www.tiktok.com/embed.js\"></script>\n\n<style>\n/* Container geral */\n.mc-tiktok-wrapper {\n  display: flex;\n  justify-content: center;\n  margin: 2rem auto;\n  max-width: 820px;\n  padding: 12px;\n  background: #fff;\n  border-radius: 20px;\n  box-shadow: 0 8px 24px rgba(0,0,0,0.08);\n  border: 2px solid #ff9ccd20; /* borda rosa bem suave */\n}\n\n/* Bordas arredondadas no player */\n.mc-tiktok-wrapper .tiktok-embed {\n  border-radius: 16px !important;\n  overflow: hidden;\n  flex: 1;\n}\n\n/* Ajustes de responsividade */\n@media (max-width: 600px) {\n  .mc-tiktok-wrapper {\n    padding: 8px;\n    border-radius: 16px;\n  }\n  .mc-tiktok-wrapper .tiktok-embed {\n    border-radius: 12px !important;\n  }\n}\n\n/* Toque MyCharms na barra inferior do TikTok embed */\n.mc-tiktok-wrapper .tiktok-embed a {\n  color: #ff9ccd !important;\n  font-weight: 600;\n  transition: color .2s ease;\n}\n.mc-tiktok-wrapper .tiktok-embed a:hover {\n  color: #d14788 !important;\n}\n</style>",
        "text_alignment": "center"
      }
