        "liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Montserrat:wght@300;400;500;600&display=swap');\n\n  .mc-tiktok {\n    padding: 5rem 0;\n    background: #fff;\n    font-family: 'Montserrat', sans-serif;\n  }\n\n  .mc-tiktok__inner {\n    max-width: 860px;\n    margin: 0 auto;\n    padding: 0 24px;\n  }\n\n  /* ── Header ── */\n  .mc-tiktok__head {\n    text-align: center;\n    margin-bottom: 2.5rem;\n  }\n\n  .mc-tiktok__kicker {\n    font-size: .65rem;\n    text-transform: uppercase;\n    letter-spacing: .35em;\n    color: #d4638f;\n    font-weight: 600;\n    margin-bottom: .8rem;\n  }\n\n  .mc-tiktok__title {\n    font-family: 'Playfair Display', serif;\n    font-size: 2.2rem;\n    font-weight: 500;\n    color: #1a1a1a;\n    margin: 0 0 .6rem;\n  }\n\n  .mc-tiktok__sub {\n    font-size: .9rem;\n    color: #888;\n    font-weight: 300;\n    max-width: 420px;\n    margin: 0 auto;\n    line-height: 1.6;\n  }\n\n  .mc-tiktok__divider {\n    width: 50px;\n    height: 2px;\n    background: #d4638f;\n    margin: 1.2rem auto 0;\n    border-radius: 2px;\n  }\n\n  /* ── Card do Embed ── */\n  .mc-tiktok__card {\n    background: #fff;\n    border-radius: 20px;\n    border: 1px solid rgba(0,0,0,.04);\n    box-shadow: 0 4px 20px rgba(0,0,0,.06);\n    padding: 16px;\n    transition: all .35s ease;\n  }\n\n  .mc-tiktok__card:hover {\n    box-shadow: 0 20px 50px rgba(212,99,143,.12);\n  }\n\n  .mc-tiktok__card .tiktok-embed {\n    border-radius: 14px !important;\n    overflow: hidden;\n    margin: 0 !important;\n    max-width: 100% !important;\n  }\n\n  /* ── Link accent ── */\n  .mc-tiktok__card .tiktok-embed a {\n    color: #d4638f !important;\n    font-weight: 600;\n    transition: color .2s ease;\n  }\n\n  .mc-tiktok__card .tiktok-embed a:hover {\n    color: #b8456f !important;\n  }\n\n  /* ── CTA inferior ── */\n  .mc-tiktok__cta-wrap {\n    text-align: center;\n    margin-top: 2rem;\n  }\n\n  .mc-tiktok__cta {\n    display: inline-flex;\n    align-items: center;\n    gap: .5rem;\n    font-family: 'Montserrat', sans-serif;\n    font-size: .72rem;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: .2em;\n    color: #d4638f;\n    text-decoration: none;\n    padding: .7rem 2rem;\n    border: 1.5px solid #d4638f;\n    border-radius: 50px;\n    background: transparent;\n    transition: all .3s ease;\n  }\n\n  .mc-tiktok__cta:hover {\n    background: #d4638f;\n    color: #fff;\n  }\n\n  .mc-tiktok__cta svg {\n    width: 16px;\n    height: 16px;\n  }\n\n  /* ── Mobile ── */\n  @media (max-width: 768px) {\n    .mc-tiktok { padding: 3rem 0; }\n    .mc-tiktok__title { font-size: 1.6rem; }\n    .mc-tiktok__card { padding: 10px; border-radius: 16px; }\n    .mc-tiktok__card .tiktok-embed { border-radius: 12px !important; }\n  }\n</style>\n\n<section class=\"mc-tiktok\">\n  <div class=\"mc-tiktok__inner\">\n\n    <div class=\"mc-tiktok__head\">\n      <p class=\"mc-tiktok__kicker\">Siga-nos</p>\n      <h2 class=\"mc-tiktok__title\">Nosso TikTok</h2>\n      <p class=\"mc-tiktok__sub\">Acompanhe novidades, bastidores e inspirações direto do nosso perfil.</p>\n      <div class=\"mc-tiktok__divider\"></div>\n    </div>\n\n    <div class=\"mc-tiktok__card\">\n      <blockquote class=\"tiktok-embed\"\n                  cite=\"https://www.tiktok.com/@my.charms.br\"\n                  data-unique-id=\"my.charms.br\"\n                  data-embed-type=\"creator\"\n                  style=\"max-width:100%; min-width:288px;\">\n        <section>\n          <a target=\"_blank\" href=\"https://www.tiktok.com/@my.charms.br?refer=creator_embed\">@my.charms.br</a>\n        </section>\n      </blockquote>\n    </div>\n\n    <div class=\"mc-tiktok__cta-wrap\">\n      <a class=\"mc-tiktok__cta\" href=\"https://www.tiktok.com/@my.charms.br\" target=\"_blank\" rel=\"noopener\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M9 5l7 7-7 7\"/></svg>\n        Seguir no TikTok\n      </a>\n    </div>\n\n  </div>\n</section>\n\n<script async src=\"https://www.tiktok.com/embed.js\"></script>",
