      "name": "t:sections.custom_liquid.presets.custom_liquid.name",
      "settings": {
        "color_scheme": "scheme-2",
        "separate_section_with_border": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": true,
        "liquid": "<!-- MyCharms — Promo Estendida (substitui section #mc-bf) -->\n<section id=\"mc-bf\" class=\"mc-bf mc-bf--premium-dark-extended\" aria-label=\"Promoção MyCharms — Estendida até 30/11\">\n  <div class=\"mc-bf__card\" role=\"region\" aria-labelledby=\"mc-bf-title\">\n    <div class=\"mc-bf__left\">\n      <div class=\"mc-bf__eyebrow\">OFERTA ESTENDIDA • MyCharms</div>\n      <h2 id=\"mc-bf-title\" class=\"mc-bf__title\">\n        CUPOM <span class=\"mc-bf__accent\">BLACKFRIDAY</span>\n        <span class=\"mc-bf__subbadge\">10% OFF</span>\n      </h2>\n      <p class=\"mc-bf__lead\">Promoção estendida: até <strong id=\"mc-bf-date\">30/11</strong>. Adicione <strong>3 peças</strong> no carrinho e o desconto <strong>15% OFF</strong> é aplicado automaticamente.</p>\n\n      <div class=\"mc-bf__timer\" aria-live=\"polite\" aria-atomic=\"true\">\n        <div class=\"mc-bf__time\"><span id=\"mc-bf-days\">00</span><small>dias</small></div>\n        <div class=\"mc-bf__sep\">:</div>\n        <div class=\"mc-bf__time\"><span id=\"mc-bf-hours\">00</span><small>hrs</small></div>\n        <div class=\"mc-bf__sep\">:</div>\n        <div class=\"mc-bf__time\"><span id=\"mc-bf-mins\">00</span><small>min</small></div>\n        <div class=\"mc-bf__sep\">:</div>\n        <div class=\"mc-bf__time\"><span id=\"mc-bf-secs\">00</span><small>seg</small></div>\n      </div>\n\n      <div class=\"mc-bf__actions\">\n        <a id=\"mc-bf-cta-primary\" class=\"mc-btn mc-btn--gold\" href=\"/discount/BLACKFRIDAY?redirect=/\">USAR BLACKFRIDAY — 10% (ou 15% com 3)</a>\n        <a class=\"mc-btn mc-btn--ghost\" href=\"{{ routes.collections_url }}\">VER COLEÇÃO</a>\n      </div>\n\n      <div class=\"mc-bf__notes\" id=\"mc-bf-summary\">\n        <strong>Resumo:</strong>\n        <span id=\"mc-bf-summary-text\">BLACKFRIDAY — 10% no checkout. <b>15% OFF</b> aplicado automaticamente ao adicionar 3+ peças. Válido até <b id=\"mc-bf-date-2\">30/11</b>.</span>\n      </div>\n    </div>\n\n    <div class=\"mc-bf__right\" aria-hidden=\"false\">\n      <div class=\"meter-top\">\n        <small>Progresso para 15% OFF</small>\n        <div class=\"meter-count\"><strong id=\"mc-bf-cart-count\">0</strong> / 3</div>\n      </div>\n\n      <div class=\"meter-bar\" role=\"progressbar\" aria-valuemin=\"0\" aria-valuemax=\"100\" aria-valuenow=\"0\">\n        <div id=\"mc-bf-bar-fill\" class=\"meter-fill\"></div>\n      </div>\n\n      <p id=\"mc-bf-hint\" class=\"mc-bf__hint\">Adicione <b>3</b> peças para garantir 15% OFF.</p>\n\n      <div id=\"mc-bf-confetti\" class=\"mc-bf-confetti\" aria-hidden=\"true\"></div>\n    </div>\n  </div>\n</section>\n\n<style>\n/* --- Reaproveita estética premium-dark, com rótulo 'Estendida' --- */\n.mc-bf--premium-dark-extended{font-family:Inter, system-ui, -apple-system, \"Helvetica Neue\", Arial; color:#efe9f3;}\n.mc-bf__card{max-width:1100px;margin:22px auto;padding:22px;border-radius:18px;display:flex;gap:20px;align-items:stretch;\n  background:linear-gradient(180deg, rgba(17,10,22,0.9), rgba(12,7,17,0.94));\n  border:1px solid rgba(255,240,200,0.03);box-shadow:0 14px 40px rgba(6,4,8,0.6);\n  position:relative;overflow:hidden;backdrop-filter: blur(6px);\n}\n.mc-bf__left{flex:1;padding:6px 6px 6px 10px}\n.mc-bf__eyebrow{display:inline-block;padding:6px 10px;border-radius:999px;background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));color:#cbb7d2;font-size:12px;letter-spacing:.08em;margin-bottom:12px}\n.mc-bf__title{margin:0 0 8px;font-size:22px;line-height:1.05;color:#fff;font-weight:800;display:flex;gap:10px;align-items:center;flex-wrap:wrap}\n.mc-bf__accent{color:#ff7ab8;background:linear-gradient(90deg,#ff7ab8,#ff9ccf);-webkit-background-clip:text;background-clip:text;color:transparent;padding:3px 8px;border-radius:8px;font-weight:900}\n.mc-bf__subbadge{font-size:13px;color:#1a0b00;background:linear-gradient(90deg,#f8e1b6,#f6c96d);padding:6px 8px;border-radius:999px;margin-left:6px;box-shadow:0 6px 18px rgba(246,201,220,0.06)}\n.mc-bf__lead{color:rgba(255,255,255,0.86);font-size:14px;margin-bottom:12px}\n.mc-bf__timer{display:flex;gap:8px;align-items:center;margin:8px 0 14px}\n.mc-bf__time{background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));padding:10px 12px;border-radius:10px;min-width:64px;text-align:center;border:1px solid rgba(255,255,255,0.02)}\n.mc-bf__time span{display:block;font-weight:800;color:#fff;font-size:16px}\n.mc-bf__time small{display:block;font-size:11px;color:rgba(255,255,255,0.5);margin-top:4px}\n.mc-bf__actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:6px}\n.mc-btn{display:inline-block;text-decoration:none;padding:12px 16px;border-radius:999px;font-weight:800;cursor:pointer}\n.mc-btn--gold{background:linear-gradient(90deg,#f6c96d,#ffd98c);color:#2a1b09;box-shadow:0 12px 30px rgba(246,201,220,0.06);border:1px solid rgba(255,255,255,0.03)}\n.mc-btn--ghost{background:transparent;border:1px solid rgba(255,255,255,0.06);color:rgba(255,255,255,0.92);padding:10px 14px}\n.mc-bf__notes{margin-top:14px;font-size:13px;color:rgba(255,255,255,0.75)}\n.mc-bf__right{width:340px;display:flex;flex-direction:column;gap:12px;align-items:stretch;justify-content:center;padding:6px}\n.meter-top{display:flex;justify-content:space-between;align-items:center}\n.meter-top small{color:rgba(255,255,255,0.6);font-size:13px}\n.meter-count{font-weight:800;color:#fff}\n.meter-bar{height:14px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:999px;border:1px solid rgba(255,255,255,0.02);overflow:hidden}\n.meter-fill{height:100%;width:0;background:linear-gradient(90deg,#ff7ab8,#f6c96d);transition:width .45s cubic-bezier(.2,.9,.22,1);box-shadow:0 8px 26px rgba(246,201,220,0.06)}\n.mc-bf__hint{font-size:13px;color:rgba(255,255,255,0.72);margin-top:6px}\n.mc-bf-confetti{position:absolute;right:18px;top:8px;pointer-events:none;z-index:20}\n@media(max-width:960px){ .mc-bf__card{flex-direction:column;padding:18px} .mc-bf__right{width:100%} .mc-bf__title{font-size:18px} .mc-bf__time{min-width:52px} }\n</style>\n\n<script>\n(function(){\n  const root = document.getElementById('mc-bf'); if(!root) return;\n  const el = id => document.getElementById(id);\n\n  // Promo estendida: alvo = 30/11/2025 23:59:59 UTC\n  const target = new Date('2025-11-30T23:59:59Z').getTime();\n\n  function tick(){\n    const now = Date.now();\n    let diff = Math.max(0, target - now);\n    const days = Math.floor(diff / 86400000); diff -= days*86400000;\n    const hours = Math.floor(diff / 3600000); diff -= hours*3600000;\n    const mins = Math.floor(diff / 60000); diff -= mins*60000;\n    const secs = Math.floor(diff / 1000);\n    el('mc-bf-days') && (el('mc-bf-days').textContent = String(days).padStart(2,'0'));\n    el('mc-bf-hours') && (el('mc-bf-hours').textContent = String(hours).padStart(2,'0'));\n    el('mc-bf-mins') && (el('mc-bf-mins').textContent = String(mins).padStart(2,'0'));\n    el('mc-bf-secs') && (el('mc-bf-secs').textContent = String(secs).padStart(2,'0'));\n    // ensure date labels show 30/11\n    el('mc-bf-date') && (el('mc-bf-date').textContent = '30/11');\n    el('mc-bf-date-2') && (el('mc-bf-date-2').textContent = '30/11');\n  }\n  tick(); setInterval(tick,1000);\n\n  // cart meter (Shopify /cart.js)\n  const confettiRoot = document.getElementById('mc-bf-confetti');\n  function spawnConfetti(){\n    if(!confettiRoot) return;\n    const colors = ['#ff7ab8','#ffd98c','#f6c96d','#ffd6f0','#b38fa0'];\n    for(let i=0;i<18;i++){\n      const d = document.createElement('div');\n      d.style.position='absolute'; d.style.width='8px'; d.style.height='8px'; d.style.borderRadius='2px';\n      d.style.background = colors[Math.floor(Math.random()*colors.length)];\n      d.style.left = (10 + Math.random()*300) + 'px'; d.style.top = '-8px';\n      confettiRoot.appendChild(d);\n      const fall = 700 + Math.random()*800;\n      d.animate([{ transform: 'translateY(0) rotate(0deg)', opacity:1 }, { transform: `translateY(${220 + Math.random()*200}px) rotate(${360*Math.random()}deg)`, opacity:0.2 }], { duration: fall, easing: 'cubic-bezier(.2,.9,.3,1)'});\n      setTimeout(()=> d.remove(), fall+80);\n    }\n  }\n\n  let confettiTriggered = false;\n  async function updateMeter(){\n    try{\n      const res = await fetch('/cart.js', { credentials: 'same-origin' });\n      const json = await res.json();\n      const count = (json && json.item_count) ? json.item_count : 0;\n      const cartCountEl = document.getElementById('mc-bf-cart-count');\n      const fillEl = document.getElementById('mc-bf-bar-fill');\n      const hintEl = document.getElementById('mc-bf-hint');\n      cartCountEl && (cartCountEl.textContent = count);\n      const pct = Math.min(100, Math.round((count/3)*100));\n      fillEl && (fillEl.style.width = pct + '%');\n      if(count >= 3){\n        hintEl && (hintEl.innerHTML = 'Desconto de <b>15% OFF</b> aplicado! 🎉');\n        const cta = document.getElementById('mc-bf-cta-primary');\n        if(cta) cta.textContent = 'GANHE 15% — IR PARA CHECKOUT';\n        if(!confettiTriggered){ confettiTriggered = true; spawnConfetti(); }\n      } else {\n        hintEl && (hintEl.innerHTML = `Adicione <b>${3-count}</b> peça(s) para 15% OFF`);\n        const cta = document.getElementById('mc-bf-cta-primary');\n        if(cta) cta.textContent = 'USAR BLACKFRIDAY — 10% (ou 15% com 3)';\n      }\n    }catch(e){\n      // silent fail\n    }\n  }\n  updateMeter(); setInterval(updateMeter,5000);\n\n  // CTA micro feedback\n  const ctaBtn = document.getElementById('mc-bf-cta-primary');\n  if(ctaBtn){\n    ctaBtn.addEventListener('click', ()=>{\n      setTimeout(()=>{ ctaBtn.classList.add('applied'); ctaBtn.textContent='CUPOM APLICADO ✅'; },500);\n    });\n  }\n})();\n</script>",
        "text_alignment": "start"
      }
    },
