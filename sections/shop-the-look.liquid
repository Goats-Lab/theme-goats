{%- if section.blocks.size > 0 -%}
  {%- assign color_scheme_hash = section.settings.color_scheme.settings.background_gradient | default: section.settings.color_scheme.settings.background | md5 -%}

  <style>
    /* ═══════════════════════════════════════════════════════════ */
    /* MyCharms — Shop the Look Overrides                        */
    /* ═══════════════════════════════════════════════════════════ */

    #shopify-section-{{ section.id }} {
      font-family: 'Montserrat', system-ui, sans-serif;
    }

    /* ── Section Header ── */
    #shopify-section-{{ section.id }} .section-header .h6 {
      font-family: 'Montserrat', system-ui, sans-serif !important;
      text-transform: uppercase !important;
      letter-spacing: 0.35em !important;
      color: #d4638f !important;
      font-size: 0.7rem !important;
      font-weight: 700 !important;
    }

    #shopify-section-{{ section.id }} .section-header .h2 {
      font-family: 'Playfair Display', serif !important;
      letter-spacing: -0.02em !important;
    }

    /* ── Look Image ── */
    #shopify-section-{{ section.id }} .shop-the-look__image,
    #shopify-section-{{ section.id }} .shop-the-look__image img {
      border-radius: 20px !important;
      overflow: hidden !important;
    }

    /* ── Hot Spots (marcadores) ── */
    #shopify-section-{{ section.id }} .shop-the-look__hot-spot {
      background: #d4638f !important;
      border: 2px solid #fff !important;
      border-radius: 50% !important;
      width: 28px !important;
      height: 28px !important;
      box-shadow: 0 4px 15px rgba(212,99,143,.35), 0 0 0 4px rgba(212,99,143,.15) !important;
      transition: all 0.4s cubic-bezier(0.22,1,0.36,1) !important;
      cursor: pointer !important;
    }

    #shopify-section-{{ section.id }} .shop-the-look__hot-spot::before {
      content: '' !important;
      position: absolute !important;
      inset: -6px !important;
      border-radius: 50% !important;
      background: rgba(212,99,143,.12) !important;
      animation: mc-pulse 2s ease-in-out infinite !important;
    }

    @keyframes mc-pulse {
      0%, 100% { transform: scale(1); opacity: 0.6; }
      50% { transform: scale(1.4); opacity: 0; }
    }

    /* ── Product Cards inside Look ── */
    #shopify-section-{{ section.id }} .product-card {
      border-radius: 16px !important;
      overflow: hidden !important;
      transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), box-shadow 0.4s ease !important;
      background: #fff !important;
    }

    #shopify-section-{{ section.id }} .product-card:hover {
      transform: translateY(-6px) !important;
      box-shadow: 0 8px 30px rgba(212,99,143,.18) !important;
    }

    #shopify-section-{{ section.id }} .product-card__figure,
    #shopify-section-{{ section.id }} .product-card__image {
      border-radius: 16px 16px 0 0 !important;
    }

    #shopify-section-{{ section.id }} .product-card__title {
      font-family: 'Montserrat', system-ui, sans-serif !important;
      font-weight: 600 !important;
      font-size: 0.9rem !important;
    }

    #shopify-section-{{ section.id }} .product-card__info {
      font-family: 'Montserrat', system-ui, sans-serif !important;
    }

    /* ── Price ── */
    #shopify-section-{{ section.id }} .price {
      font-family: 'Montserrat', system-ui, sans-serif !important;
      font-weight: 700 !important;
    }

    /* ── Popover / Mobile Panel ── */
    #shopify-section-{{ section.id }} .shop-the-look__popover,
    #shopify-section-{{ section.id }} .shop-the-look__mobile-panel {
      border-radius: 20px !important;
      box-shadow: 0 12px 40px rgba(0,0,0,.10) !important;
      overflow: hidden !important;
      background: #fff !important;
    }

    #shopify-section-{{ section.id }} .shop-the-look__popover-title,
    #shopify-section-{{ section.id }} .shop-the-look__mobile-panel h2 {
      font-family: 'Playfair Display', serif !important;
      letter-spacing: -0.02em !important;
      font-size: 1.1rem !important;
    }

    /* ── Desktop Product Sidebar ── */
    #shopify-section-{{ section.id }} .shop-the-look__products {
      border-radius: 20px !important;
      background: #fafafa !important;
      padding: 1.5rem !important;
      box-shadow: 0 2px 15px rgba(0,0,0,.05) !important;
    }

    /* ── CTA Button ── */
    #shopify-section-{{ section.id }} .button:not(.circle-button):not([class*="prev-next"]) {
      background: #d4638f !important;
      border-color: #d4638f !important;
      border-radius: 50px !important;
      color: #fff !important;
      font-family: 'Montserrat', system-ui, sans-serif !important;
      font-weight: 700 !important;
      letter-spacing: 0.08em !important;
      text-transform: uppercase !important;
      font-size: 0.8rem !important;
      padding: 0.85rem 2rem !important;
      transition: all 0.3s cubic-bezier(0.22,1,0.36,1) !important;
    }

    #shopify-section-{{ section.id }} .button:not(.circle-button):not([class*="prev-next"]):hover {
      background: #b84d76 !important;
      border-color: #b84d76 !important;
      box-shadow: 0 8px 30px rgba(212,99,143,.25) !important;
      transform: translateY(-2px) !important;
    }

    /* ── Carousel Arrows ── */
    #shopify-section-{{ section.id }} .prev-next-button,
    #shopify-section-{{ section.id }} .circle-button {
      border-radius: 50% !important;
      border: 1px solid rgba(17,17,17,.08) !important;
      width: 44px !important;
      height: 44px !important;
      background: #fff !important;
      box-shadow: 0 2px 10px rgba(0,0,0,.06) !important;
      transition: all 0.3s ease !important;
    }

    #shopify-section-{{ section.id }} .prev-next-button:hover,
    #shopify-section-{{ section.id }} .circle-button:hover {
      background: #d4638f !important;
      border-color: #d4638f !important;
      color: #fff !important;
      box-shadow: 0 4px 15px rgba(212,99,143,.3) !important;
    }

    /* ── Pagination Dots ── */
    #shopify-section-{{ section.id }} .page-dots button {
      transition: all 0.3s ease !important;
    }

    #shopify-section-{{ section.id }} .page-dots button[aria-current="true"] {
      color: #d4638f !important;
    }

    #shopify-section-{{ section.id }} .page-dots .circular-progress circle:last-child {
      stroke: #d4638f !important;
    }

    /* ── Badges ── */
    #shopify-section-{{ section.id }} .badge {
      border-radius: 999px !important;
      font-family: 'Montserrat', system-ui, sans-serif !important;
      font-weight: 700 !important;
      letter-spacing: 0.08em !important;
      text-transform: uppercase !important;
      font-size: 0.65rem !important;
    }

    /* ── Discount Badge ── */
    #shopify-section-{{ section.id }} .discount-badge {
      background: rgba(212,99,143,.12) !important;
      color: #d4638f !important;
      border-radius: 999px !important;
    }

    /* ── Carousel container ── */
    #shopify-section-{{ section.id }} .shop-the-look__carousel,
    #shopify-section-{{ section.id }} .scroll-area {
      border-radius: 20px !important;
    }

    /* ── Quick Buy ── */
    #shopify-section-{{ section.id }} .product-card .quick-buy-drawer,
    #shopify-section-{{ section.id }} .product-card .quick-buy-modal {
      border-radius: 20px !important;
    }

    /* ── Hot spot hover ── */
    @media (hover:hover) {
      #shopify-section-{{ section.id }} .shop-the-look__hot-spot:hover {
        transform: scale(1.15) !important;
        box-shadow: 0 6px 20px rgba(212,99,143,.45), 0 0 0 6px rgba(212,99,143,.12) !important;
      }
    }

    #shopify-section-{{ section.id }} .shop-the-look__hot-spot:focus-visible {
      outline: 2px solid #d4638f !important;
      outline-offset: 3px !important;
    }
  </style>

  <div class="section-spacing {% if section.settings.separate_section_with_border %}bordered-section{% endif %} color-scheme color-scheme--{{ section.settings.color_scheme.id }} color-scheme--bg-{{ color_scheme_hash }}">
    <div class="container">
      <div class="section-stack">

        {%- render 'section-header',
          subheading: section.settings.subheading,
          heading: section.settings.title,
          content: section.settings.content
        -%}

        {%- for i in (1..2) -%}
          {%- capture device -%}{% cycle 'mobile', 'desktop' %}{%- endcapture -%}

          {%- capture content -%}
            {%- for block in section.blocks -%}
              {%- liquid
                assign show_placeholder = false
                assign look_image_loading_strategy = nil
                assign products_count = 0

                unless forloop.first
                  assign look_image_loading_strategy = 'lazy'
                endunless

                for product_index in (1..4)
                  assign product_id = 'product_' | append: product_index
                  if block.settings[product_id] != blank
                    assign products_count = products_count | plus: 1
                  endif
                endfor

                if products_count == 0
                  assign show_placeholder = true
                  assign products_count = 3
                endif
              -%}

              <div class="shop-the-look" {{ block.shopify_attributes }}>
                <div class="shop-the-look__image">
                  {%- if block.settings.image != blank -%}
                    {%- capture sizes -%}(max-width: 999px) 100vw, min(60vw, 550px){%- endcapture -%}
                    {%- assign fetch_priority = 'auto' -%}
                    {%- if forloop.parentloop.first and device == 'desktop' -%}
                      {%- assign fetch_priority = 'high' -%}
                    {%- endif -%}
                    {{- block.settings.image
                      | image_url: width: block.settings.image.width
                      | image_tag:
                          loading: look_image_loading_strategy,
                          widths: '400,500,600,700,800,1000,1200,1400,1600,1800',
                          sizes: sizes,
                          class: 'image-cover',
                          fetchpriority: fetch_priority
                    -}}
                  {%- else -%}
                    {%- capture placeholder -%}{% cycle 'collection-1', 'collection-2', 'collection-3', 'collection-4' %}{%- endcapture -%}
                    {{- placeholder | placeholder_svg_tag: 'placeholder--invert' | replace: '<svg', '<svg preserveAspectRatio="xMidYMid slice"' -}}
                  {%- endif -%}

                  <div class="shop-the-look__hot-spots">
                    {%- for product_index in (1..products_count) -%}
                      {%- capture horizontal_position_id -%}product_{{ product_index }}_horizontal_position{%- endcapture -%}
                      {%- capture vertical_position_id -%}product_{{ product_index }}_vertical_position{%- endcapture -%}

                      <button type="button" class="shop-the-look__hot-spot" aria-controls="look-products" style="left:{{ block.settings[horizontal_position_id] }}%;top:{{ block.settings[vertical_position_id] }}%;--hot-spot-background:{{ block.settings.hot_spots_background }}">
                        {{- 'general.accessibility.go_to_item' | t: index: product_index -}}
                      </button>
                    {%- endfor -%}
                  </div>
                </div>

                {%- if device == 'mobile' -%}
                  <div class="shop-the-look__mobile-panel">
                    <h2 class="shop-the-look__popover-title">{{ section.settings.popover_title }}</h2>

                    <div class="shop-the-look__mobile-products">
                      {%- for product_index in (1..products_count) -%}
                        <div class="shop-the-look__mobile-product">
                          {%- unless show_placeholder -%}
                            {%- capture product_id -%}product_{{ product_index }}{%- endcapture -%}
                            {%- capture quick_buy_context -%}mobile-{{ block.id }}{%- endcapture -%}
                            {%- render 'product-card', product: block.settings[product_id], show_vendor: settings.show_vendor, show_rating: settings.show_rating, quick_buy_context: quick_buy_context -%}
                          {%- else -%}
                            {%- render 'product-card-placeholder', loop_index: forloop.index0, show_vendor: settings.show_vendor, show_rating: settings.show_rating -%}
                          {%- endunless -%}
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- else -%}
                  <div class="shop-the-look__products">
                    <div class="shop-the-look__products-list">
                      {%- for product_index in (1..products_count) -%}
                        <div class="shop-the-look__product-item">
                          {%- unless show_placeholder -%}
                            {%- capture product_id -%}product_{{ product_index }}{%- endcapture -%}
                            {%- capture quick_buy_context -%}desktop-{{ block.id }}{%- endcapture -%}
                            {%- render 'product-card', product: block.settings[product_id], show_vendor: settings.show_vendor, show_rating: settings.show_rating, quick_buy_context: quick_buy_context -%}
                          {%- else -%}
                            {%- render 'product-card-placeholder', loop_index: forloop.index0, show_vendor: settings.show_vendor, show_rating: settings.show_rating -%}
                          {%- endunless -%}
                        </div>
                      {%- endfor -%}
                    </div>

                    {%- assign button_text = 'Ver produto' -%}
                    {%- assign href_attribute = block.settings.product_1.url | default: '#' -%}
                    {%- render 'button', href: href_attribute, content: button_text -%}

                    {%- if products_count > 1 -%}
                      <div class="page-dots">
                        {%- for i in (1..products_count) -%}
                          <button type="button" aria-current="{% if forloop.first %}true{% else %}false{% endif %}">
                            {{- 'general.accessibility.go_to_item' | t: index: forloop.index -}}
                          </button>
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {% endcapture %}

          <div class="shop-the-look__carousel shop-the-look__carousel--{{ device }}">
            {%- if device == 'mobile' -%}
              <div class="shop-the-look__mobile-wrapper">
                <div class="scroll-area">
                  {{- content -}}
                </div>

                {%- assign button_text = 'Ver produtos' -%}
                {%- render 'button', type: 'button', content: button_text, stretch: true -%}
              </div>
            {%- else -%}
              <div class="shop-the-look__desktop-wrapper">
                {%- if section.blocks.size > 1 -%}
                  <div class="prev-next-button prev-next-button--prev">
                    <button type="button">
                      {{ 'general.accessibility.previous' | t }}
                      {%- render 'icon' with 'arrow-left', direction_aware: true -%}
                    </button>
                  </div>
                {%- endif -%}

                <div class="scroll-area">
                  {{- content -}}
                </div>

                {%- if section.blocks.size > 1 -%}
                  <div class="prev-next-button prev-next-button--next">
                    <button type="button">
                      {{ 'general.accessibility.next' | t }}
                      {%- render 'icon' with 'arrow-right', direction_aware: true -%}
                    </button>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}

      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Compre o look (MyCharms)",
  "class": "shopify-section--shop-the-look",
  "tag": "section",
  "max_blocks": 5,
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de cores",
      "default": "scheme-2"
    },
    {
      "type": "checkbox",
      "id": "separate_section_with_border",
      "label": "Separar seção com borda",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Título",
      "default": "Compre o look"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Descrição"
    },
    {
      "type": "inline_richtext",
      "id": "popover_title",
      "label": "Título do popover",
      "default": "Compre o look"
    }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem",
          "info": "Use foto vertical de alta resolução para melhor recorte"
        },
        {
          "type": "color",
          "id": "hot_spots_background",
          "label": "Cor dos marcadores",
          "default": "#d4638f"
        },
        { "type": "header", "content": "Produto 1" },
        { "type": "product", "id": "product_1", "label": "Produto" },
        { "type": "range", "id": "product_1_horizontal_position", "label": "Posição horizontal (%)", "min": 5, "max": 95, "step": 1, "unit": "%", "default": 55 },
        { "type": "range", "id": "product_1_vertical_position", "label": "Posição vertical (%)", "min": 5, "max": 95, "step": 1, "unit": "%", "default": 30 },

        { "type": "header", "content": "Produto 2" },
        { "type": "product", "id": "product_2", "label": "Produto" },
        { "type": "range", "id": "product_2_horizontal_position", "label": "Posição horizontal (%)", "min": 5, "max": 95, "step": 1, "unit": "%", "default": 25 },
        { "type": "range", "id": "product_2_vertical_position", "label": "Posição vertical (%)", "min": 5, "max": 95, "step": 1, "unit": "%", "default": 40 },

        { "type": "header", "content": "Produto 3" },
        { "type": "product", "id": "product_3", "label": "Produto" },
        { "type": "range", "id": "product_3_horizontal_position", "label": "Posição horizontal (%)", "min": 5, "max": 95, "step": 1, "unit": "%", "default": 65 },
        { "type": "range", "id": "product_3_vertical_position", "label": "Posição vertical (%)", "min": 10, "max": 95, "step": 1, "unit": "%", "default": 60 },

        { "type": "header", "content": "Produto 4" },
        { "type": "product", "id": "product_4", "label": "Produto" },
        { "type": "range", "id": "product_4_horizontal_position", "label": "Posição horizontal (%)", "min": 5, "max": 95, "step": 1, "unit": "%", "default": 85 },
        { "type": "range", "id": "product_4_vertical_position", "label": "Posição vertical (%)", "min": 10, "max": 95, "step": 1, "unit": "%", "default": 85 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Compre o look",
      "blocks": [
        {
          "type": "look",
          "settings": {
            "product_1_horizontal_position": 35,
            "product_1_vertical_position": 35,
            "product_2_horizontal_position": 34,
            "product_2_vertical_position": 65,
            "product_3_horizontal_position": 66,
            "product_3_vertical_position": 42
          }
        },
        {
          "type": "look",
          "settings": {
            "product_1_horizontal_position": 30,
            "product_1_vertical_position": 35,
            "product_2_horizontal_position": 70,
            "product_2_vertical_position": 30,
            "product_3_horizontal_position": 60,
            "product_3_vertical_position": 65
          }
        }
      ]
    }
  ]
}
{% endschema %}
