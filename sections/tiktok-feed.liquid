{% comment %}
  TIKTOK – Carrossel • MyCharms (Estética Premium)
{% endcomment %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Montserrat:wght@300;400;500;600&display=swap');

  .mc-tk {
    padding: 5rem 0;
    background: #fff;
    font-family: 'Montserrat', sans-serif;
    overflow: hidden;
  }

  .mc-tk__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Header ── */
  .mc-tk__head {
    text-align: center;
    margin-bottom: 3rem;
  }

  .mc-tk__kicker {
    font-size: .65rem;
    text-transform: uppercase;
    letter-spacing: .35em;
    color: #d4638f;
    font-weight: 600;
    margin-bottom: .8rem;
  }

  .mc-tk__title {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0 0 .6rem;
  }

  .mc-tk__sub {
    font-size: .9rem;
    color: #888;
    font-weight: 300;
    max-width: 460px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .mc-tk__divider {
    width: 50px;
    height: 2px;
    background: #d4638f;
    margin: 1.2rem auto 0;
    border-radius: 2px;
  }

  /* ── Track ── */
  .mc-tk__track-wrap {
    position: relative;
  }

  .mc-tk__track {
    display: flex;
    gap: {{ section.settings.gap }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding: 0 24px 1.5rem;
    scrollbar-width: none;
  }

  .mc-tk__track::-webkit-scrollbar { display: none; }

  .mc-tk__track:focus {
    outline: 2px solid #d4638f;
    outline-offset: 3px;
    border-radius: 12px;
  }

  /* ── Card ── */
  .mc-tk__card {
    scroll-snap-align: center;
    flex: 0 0 {{ section.settings.item_w_mobile }}%;
    min-width: 0;
    border-radius: {{ section.settings.radius }}px;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(0,0,0,.04);
    box-shadow: 0 4px 20px rgba(0,0,0,.06);
    transition: all .35s ease;
  }

  .mc-tk__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(212,99,143,.12);
  }

  @media (min-width: 900px) {
    .mc-tk__card {
      flex-basis: {{ section.settings.item_w_desktop }}%;
    }
  }

  .mc-tk__embed {
    border-radius: {{ section.settings.radius }}px {{ section.settings.radius }}px 0 0;
    overflow: hidden;
    background: #fafafa;
    min-height: 320px;
  }

  .mc-tk__embed iframe,
  .mc-tk__embed blockquote {
    width: 100% !important;
    border: none;
  }

  .mc-tk__caption {
    padding: .8rem 1rem 1rem;
    font-size: .78rem;
    color: #888;
    line-height: 1.5;
    font-weight: 400;
    text-align: center;
  }

  /* ── Arrows ── */
  .mc-tk__arrows {
    display: flex;
    justify-content: center;
    gap: .75rem;
    margin-top: 2rem;
  }

  .mc-tk__arr {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid #e0e0e0;
    background: #fff;
    color: #1a1a1a;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .25s ease;
  }

  .mc-tk__arr:hover {
    background: #d4638f;
    border-color: #d4638f;
    color: #fff;
  }

  .mc-tk__arr svg {
    width: 18px;
    height: 18px;
    stroke-width: 2;
  }

  @media (max-width: 768px) {
    .mc-tk { padding: 3rem 0; }
    .mc-tk__title { font-size: 1.6rem; }
    .mc-tk__arrows { display: none; }
  }
</style>

<section class="mc-tk">
  <div class="mc-tk__inner">

    {% if section.settings.title != blank or section.settings.subtitle != blank or section.settings.kicker != blank %}
      <div class="mc-tk__head">
        {% if section.settings.kicker != blank %}
          <p class="mc-tk__kicker">{{ section.settings.kicker }}</p>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="mc-tk__title">{{ section.settings.title }}</h2>
        {% endif %}

        {% if section.settings.subtitle != blank %}
          <p class="mc-tk__sub">{{ section.settings.subtitle }}</p>
        {% endif %}

        <div class="mc-tk__divider"></div>
      </div>
    {% endif %}

    <div class="mc-tk__track-wrap">
      <div class="mc-tk__track" id="mc-tk-track" tabindex="0" aria-label="Carrossel TikTok">
        {% for block in section.blocks %}
          <div class="mc-tk__card" {{ block.shopify_attributes }}>
            <div class="mc-tk__embed">
              {{ block.settings.embed_code }}
            </div>

            {% if block.settings.caption != blank %}
              <p class="mc-tk__caption">{{ block.settings.caption }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if section.settings.show_arrows %}
        <div class="mc-tk__arrows">
          <button class="mc-tk__arr" aria-label="Anterior"
            onclick="document.getElementById('mc-tk-track').scrollBy({left:-320,behavior:'smooth'})">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button class="mc-tk__arr" aria-label="Próximo"
            onclick="document.getElementById('mc-tk-track').scrollBy({left:320,behavior:'smooth'})">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      {% endif %}
    </div>

  </div>
</section>

{%- comment -%} TikTok embed script {%- endcomment -%}
<script async src="https://www.tiktok.com/embed.js"></script>

{% schema %}
{
  "name": "TikTok Carousel",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de cores" },
    { "type": "text", "id": "kicker", "label": "Kicker (pequeno)", "default": "Feedbacks reais" },
    { "type": "text", "id": "title", "label": "Título", "default": "O que a galera posta no TikTok" },
    { "type": "textarea", "id": "subtitle", "label": "Subtítulo", "default": "Conteúdo criado por clientes e pela nossa equipe." },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Alinhamento do título",
      "default": "center",
      "options": [
        { "value": "left", "label": "Esquerda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Direita" }
      ]
    },
    {
      "type": "color",
      "id": "brand_color",
      "label": "Cor de destaque (TikTok)",
      "default": "#d4638f"
    },
    { "type": "checkbox", "id": "show_arrows", "label": "Mostrar setas", "default": true },
    { "type": "range", "id": "gap", "min": 8, "max": 32, "step": 2, "label": "Espaçamento entre cards (px)", "default": 16 },
    { "type": "range", "id": "radius", "min": 0, "max": 24, "step": 2, "label": "Arredondamento dos cantos (px)", "default": 16 },
    { "type": "range", "id": "item_w_mobile", "min": 60, "max": 100, "step": 2, "label": "Largura do card no mobile (%)", "default": 88 },
    { "type": "range", "id": "item_w_desktop", "min": 20, "max": 50, "step": 2, "label": "Largura do card no desktop (%)", "default": 32 }
  ],
  "blocks": [
    {
      "type": "embed",
      "name": "Código TikTok",
      "settings": [
        {
          "type": "textarea",
          "id": "embed_code",
          "label": "Código de incorporação",
          "info": "Cole o embed do TikTok (vídeo, perfil, hashtag)."
        },
        { "type": "text", "id": "caption", "label": "Legenda curta (opcional)" }
      ]
    }
  ],
  "presets": [
    { "name": "TikTok Carousel", "category": "Social" }
  ]
}
{% endschema %}
